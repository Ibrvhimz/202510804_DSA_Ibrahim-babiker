#include <iostream>
using namespace std;

int main() {

    int numbers[] = {2, 5, 8, 12, 16, 23, 38, 56};

    int size = 8;
    int key;

    int low = 0;
    int high = size - 1;

    bool found = false;

    cout << "Enter number to search: ";
    cin >> key;

    while (low <= high) {

        int mid = (low + high) / 2;

        if (numbers[mid] == key) {

            cout << key << " was found at position "
                 << mid << endl;

            found = true;
            break;
        }

        else if (numbers[mid] < key) {

            low = mid + 1;
        }

        else {

            high = mid - 1;
        }
    }

    if (!found) {

        cout << "Number not found";
    }

    return 0;
}
